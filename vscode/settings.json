{
  "editor.fontFamily": "'JetBrains Mono', Consolas, 'Courier New', monospace",
  "workbench.colorTheme": "Dark Modern",
  "editor.minimap.enabled": false,
  // Relative line numbers
  "editor.lineNumbers": "relative",

  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  // Disable keys
  "vim.handleKeys": {
    "<C-p>": false,
    "<C-w>": false,
    "<C-k>": false
  },
  // Disable Ctrl+C in insert mode (<Nop>)
  "vim.insertModeKeyBindings": [
    {
      "before": ["<C-c>"],
      "commands": []
    },
    // jk → Esc
    {
      "before": ["j", "k"],
      "after": ["<Esc>"]
    }
  ],
  "vim.normalModeKeyBindingsNonRecursive": [
    // Centers cursor after half-page scroll and search navigation
    {
      "before": ["<C-d>"],
      "after": ["<C-d>", "z", "z"]
    },
    // Centers cursor after half-page scroll and search navigation
    {
      "before": ["<C-u>"],
      "after": ["<C-u>", "z", "z"]
    },
    // Centers cursor after search navigation
    {
      "before": ["n"],
      "after": ["n", "z", "z", "z", "v"]
    },
    // Centers cursor after search navigation
    {
      "before": ["N"],
      "after": ["N", "z", "z", "z", "v"]
    },
    // Sets Ctrl+R (redo) to U, allowing IDEs to use CTRL+R for renaming references
    {
      "before": ["U"],
      "after": ["<C-r>"]
    }
  ],
  // Equivalent to: set timeoutlen=300
  "vim.timeout": 300,
  "terminal.integrated.defaultProfile.windows": "Git Bash",
  "chat.viewSessions.orientation": "stacked"
}
